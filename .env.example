APP_NAME='MiniWorld App'
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=miniworld-app
DB_USERNAME=postgres
DB_PASSWORD=admin

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

QUEUE_CONNECTION=redis
CACHE_DRIVER=file
HORIZON_NAME="MiniWorld"
HORIZON_PREFIX="miniworld-app_horizon:"

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

PULSE_PASSWORD=admin

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=your-email@example.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME=${APP_NAME}
VITE_API_URL="${APP_URL}"
VITE_APP_ENV=${APP_ENV}
VITE_APP_DEBUG=true
VITE_APP_VERSION=0.0.0

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

SANCTUM_STATEFUL_DOMAINS=localhost:8001,localhost
SESSION_DOMAIN=null

SCOUT_DRIVER=null

APP_ADMIN_EMAIL="admin@admin.com"
APP_ADMIN_PASSWORD="123"
APP_ADMIN_ROLE="Administrador"
APP_DER_KEY="starterkey"
